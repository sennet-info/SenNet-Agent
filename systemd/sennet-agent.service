[Unit]
Description=SenNet Agent Streamlit UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=debian
WorkingDirectory=/opt/sennet-agent/repo/app
Environment="PATH=/opt/sennet-agent/venv/bin"
ExecStart=/opt/sennet-agent/venv/bin/streamlit run app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
