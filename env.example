# SenNet Agent — variables de entorno
# Copia a /opt/sennet-agent/env y rellena los valores reales.
# NUNCA subir este archivo al repositorio.

# Token de administración (genera uno con: openssl rand -hex 32)
AGENT_ADMIN_TOKEN=cambia-este-token

# URL base del agente
AGENT_BASE_URL=http://127.0.0.1:8000

# Rutas de persistencia (opcional si usas las rutas por defecto)
# SCHEDULED_TASKS_PATH=/opt/sennet-agent/scheduled_tasks.json
# SMTP_CONFIG_PATH=/opt/sennet-agent/smtp_config.json
